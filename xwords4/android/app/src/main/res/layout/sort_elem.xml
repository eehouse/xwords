<?xml version="1.0" encoding="utf-8"?>

<org.eehouse.android.xw4.SortTableRow
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    >

  <!-- Two buttons or one Checkbox will be hidden -->
  <ImageButton android:id="@+id/arrow_up"
               android:src="@drawable/arrow_upward_24dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               />
  <ImageButton android:id="@+id/arrow_down"
               android:src="@drawable/arrow_downward_24dp"
               android:layout_width="wrap_content"
               android:layout_height="wrap_content"
               />
  <CheckBox android:id="@+id/so_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />

  <TextView android:id="@+id/so_name"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:layout_marginRight="8dp"
            />
  <CheckBox android:id="@+id/so_inverted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/so_inverted"
            />
</org.eehouse.android.xw4.SortTableRow>
