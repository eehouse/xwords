<?xml version="1.0" encoding="utf-8"?>

<org.eehouse.android.xw4.SortTableRow
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    >

  <!-- Two buttons or one Checkbox will be hidden -->
  <Button android:id="@+id/arrow_up"
          android:layout_width="36dp"
          android:layout_height="match_parent"
          android:text="▲"
          />
  <Button android:id="@+id/arrow_down"
            android:layout_width="36dp"
            android:layout_height="match_parent"
            android:text="▼"
            />
  <CheckBox android:id="@+id/so_selected"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            />

  <TextView android:id="@+id/so_name"
            android:layout_height="wrap_content"
            android:layout_width="wrap_content"
            android:textAppearance="?android:attr/textAppearanceMedium"
            android:layout_marginRight="8dp"
            />
  <CheckBox android:id="@+id/so_inverted"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="@string/so_inverted"
            />
</org.eehouse.android.xw4.SortTableRow>
